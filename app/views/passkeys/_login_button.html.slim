css:
  #passkey-login {
    margin-top: 0.6em;
  }
  #passkey-login button {
    display: block;
    width: 100%;
    padding: 8px 16px;
    font-size: 1em;
    font-family: inherit;
    text-align: center;
    cursor: pointer;
    border-radius: 3px;
    box-sizing: border-box;
    line-height: 1.5;
  }

#passkey-login
  button#passkey-login-btn type="button"
    = l(:button_login_with_passkey)

= javascript_include_tag 'webauthn', plugin: 'redmine_passkey'
