<h2>Passkey 管理</h2>

<% if @credentials.any? %>
  <table class="list">
    <thead>
      <tr>
        <th>名前</th>
        <th>登録日時</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @credentials.each do |cred| %>
        <tr>
          <td><%= cred.nickname %></td>
          <td><%= format_time(cred.created_at) %></td>
          <td><%= link_to '削除', passkey_path(cred), method: :delete, data: { confirm: '削除しますか？' } %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>登録済みのPasskeyはありません。</p>
<% end %>

<hr />
<h3>新しいPasskeyを登録</h3>
<input type="text" id="passkey-nickname" placeholder="例: MacBook Touch ID" />
<button onclick="registerPasskey(document.getElementById('passkey-nickname').value)">
  Passkeyを登録
</button>

<%= javascript_include_tag 'webauthn', plugin: 'redmine_passkey' %>
